rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(tenantId) {
      return isAuthenticated() && request.auth.uid == tenantId;
    }

    function isOwnerOrAdmin(tenantId) {
      return isOwner(tenantId) || isAdmin();
    }

    // Tenant root document
    match /tenants/{tenantId} {
      allow read: if isOwnerOrAdmin(tenantId);
      allow create: if isOwner(tenantId);
      allow update: if isOwnerOrAdmin(tenantId);
      allow delete: if isAdmin();
    }

    // Issues — tenants/{tenantId}/issues/{yearMonth}
    match /tenants/{tenantId}/issues/{issueId} {
      allow read: if isOwnerOrAdmin(tenantId);
      allow create: if isOwnerOrAdmin(tenantId);
      allow update: if isOwnerOrAdmin(tenantId);
      allow delete: if isAdmin();

      // Public access for published issues (shareable link)
      allow get: if resource.data.status == 'published';
    }

    // Settings
    match /tenants/{tenantId}/settings/{settingId} {
      allow read, write: if isOwnerOrAdmin(tenantId);
    }

    // Campaigns
    match /tenants/{tenantId}/campaigns/{campaignId} {
      allow read, write: if isOwnerOrAdmin(tenantId);
    }

    // Assets
    match /tenants/{tenantId}/assets/{assetId} {
      allow read, write: if isOwnerOrAdmin(tenantId);
    }

    // Catch-all for admin access to any tenant subcollection
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
